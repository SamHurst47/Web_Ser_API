.gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
.env.*
venv/
.venv/
env/
.conda/
.pyenv/

# OS / Editor junk
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
logs/

# SQLite / local DBs
*.db
*.sqlite3

# Test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/

# Build / dist
build/
dist/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# FastAPI / UVicorn reload artifacts
*.pid
